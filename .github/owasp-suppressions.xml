<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency Check — Suppressions File
  Usado para suprimir falsos positivos no OWASP Dependency Check.
  
  Como usar:
  1. Identifique o CVE que é um falso positivo
  2. Adicione uma entrada <suppress> com a justificativa documentada
  3. Inclua a data de revisão (reviewDate) para auditoria periódica
  
  Documentação: https://jeremylong.github.io/DependencyCheck/general/suppressing.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
      Adicione supressões aqui conforme necessário.
      Exemplo de formato:
      
      <suppress until="2025-12-31Z">
        <notes>CVE-YYYY-NNNNN: Falso positivo — nossa versão não é afetada porque [justificativa].
               Revisado em: YYYY-MM-DD por: [nome]</notes>
        <packageUrl regex="true">^pkg:maven/com\.example/some-library@.*$</packageUrl>
        <cve>CVE-YYYY-NNNNN</cve>
      </suppress>
    -->

</suppressions>
